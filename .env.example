# Copy to .env and fill in. Loaded automatically via process.loadEnvFile()
# (or run: node --env-file=.env src/index.js)

# --- Discord (required) ---
DISCORD_TOKEN=your-bot-token
DISCORD_CLIENT_ID=your-application-id
DISCORD_CLIENT_SECRET=your-application-client-secret
# Optional: set to one server's ID to register slash commands instantly (dev).
# Leave blank to register globally (takes up to ~1h to propagate).
DISCORD_GUILD_ID=
# Optional: deploy slash commands when the bot process starts.
DEPLOY_DISCORD_COMMANDS=false

# --- PandaScore (VCT, LCS/Worlds, IEM/CS2, RLCS, OWCS, ...) ---
PANDASCORE_TOKEN=
PANDASCORE_BASE_URL=https://api.pandascore.co
PANDASCORE_PROFILES_ENABLED=false
PANDASCORE_PROFILES_CRON=30 3 * * *
PANDASCORE_PROFILES_TIMEZONE=Asia/Riyadh
PANDASCORE_PROFILES_GAMES=
PANDASCORE_PROFILES_QUIET_START_HOUR=2
PANDASCORE_PROFILES_QUIET_END_HOUR=6
PANDASCORE_PROFILES_MIN_GAP_MS=1500
PANDASCORE_PROFILES_BACKOFF_MS=1200000
PANDASCORE_PROFILES_PER_PAGE=50
PANDASCORE_PROFILES_MAX_PAGES=3

# --- Logo warmup (pre-download Liquipedia images for the web logo proxy) ---
# The web /api/logo proxy serves only images the bot has already cached; it never
# fetches upstream on public page views. This job warms EWC player portraits,
# tracked-match crests, standings crests, and entity images through the existing
# serial, shared-rate-state, back-off-protected queue.
LOGO_WARMUP_ENABLED=true
LOGO_WARMUP_CRON=20 */3 * * *
LOGO_WARMUP_TIMEZONE=Asia/Riyadh
LOGO_WARMUP_MAX_DOWNLOADS_PER_RUN=80
LOGO_WARMUP_BOOT_DELAY_MS=180000

# --- Liquipedia entity enrichment (teams/players; primary source for BR games + TFT) ---
# Quiet-hours job that resolves tracked-match team names to Liquipedia pages and
# parses team/player infoboxes + rosters through the SAME serialized queue as
# tournament parsing. Capped per run; entities (hits and misses) are stamped and
# not retried until the TTL lapses.
LIQUIPEDIA_ENRICH_ENABLED=false
LIQUIPEDIA_ENRICH_CRON=45 4 * * *
LIQUIPEDIA_ENRICH_TIMEZONE=Asia/Riyadh
LIQUIPEDIA_ENRICH_MAX_PARSES=60   # temporary backfill budget; lower to 12 after catch-up
LIQUIPEDIA_ENRICH_TTL_DAYS=30
LIQUIPEDIA_ROSTER_BACKFILL_BEFORE=2026-07-07T00:00:00Z
LIQUIPEDIA_PLAYER_IMAGE_BACKFILL_BEFORE=2026-07-07T00:00:00Z

# --- BR/TFT standings tracking (events with no head-to-head matches) ---
# Re-parses active battle-royale / TFT event pages on a gentle cadence (one
# parse per event per sweep, through the shared serialized Liquipedia queue).
STANDINGS_SYNC_ENABLED=true
STANDINGS_SYNC_CRON=10 */3 * * *
STANDINGS_SYNC_TIMEZONE=Asia/Riyadh
STANDINGS_SYNC_BOOT_DELAY_MS=45000

# --- Start.gg (brackets; EWC + community events) ---
STARTGG_TOKEN=
# start.gg allows 80 requests / 60s. Default keeps us at 60/min; code floors this at 750ms.
STARTGG_MIN_GAP_MS=1000
STARTGG_BACKOFF_MS=1200000
STARTGG_RATE_STATE_PATH=data/startgg-rate-limit.json

# --- Live co-stream detection (optional) ---
# When a platform's client id + secret are set, the stream-status poller checks each
# tracked co-stream channel (admin /admin/streams) and records who's currently live.
# Twitch: register an app at https://dev.twitch.tv/console
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# Kick: create an app at kick.com -> Settings -> Developer
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=
# Optional: how often to poll live status, in seconds (min 30, default 60).
STREAM_STATUS_POLL_SECONDS=60
# YouTube live status needs NO credentials (public /live page probe) but polls on
# its own slower cadence (min 120, default 180). Set ENABLED=false to turn it off.
STREAM_STATUS_YOUTUBE_ENABLED=true
STREAM_STATUS_YOUTUBE_POLL_SECONDS=180

# --- Liquipedia (PRIMARY, free) - REQUIRED by their ToS: identify app + a real contact ---
LIQUIPEDIA_USER_AGENT=EsportsCommunityBot/1.0 (you@example.com)
LIQUIPEDIA_PARSE_MIN_GAP_MS=30000
LIQUIPEDIA_CACHE_TTL_MS=900000
LIQUIPEDIA_BACKOFF_MS=1200000
LIQUIPEDIA_RATE_STATE_PATH=data/liquipedia-rate-limit.json
# Refresh supported Match: detail pages while live, then once after completion.
LIQUIPEDIA_MATCH_DETAILS_ENABLED=true
# Hard ceiling (bytes) on a single Liquipedia response body — defense-in-depth
# against a runaway upstream. Default 50 MB; real responses are far smaller. Only
# raise it if a legitimate page ever exceeds it (it should not).
LIQUIPEDIA_MAX_RESPONSE_BYTES=52428800
# Optional: LiquipediaDB API key (structured JSON, 60 req/hr). When set, it's preferred over
# HTML parsing. Leave blank to use the free MediaWiki parsing (current default).
LPDB_API_KEY=
# Liquipedia search (autocomplete) pacing
LIQUIPEDIA_SEARCH_MIN_GAP_MS=2500
LIQUIPEDIA_SEARCH_CACHE_TTL_MS=600000
LIQUIPEDIA_SEARCH_MAX_QUEUE=12

# --- Scheduler ---
SCHEDULER_TIMEZONE=UTC
MORNING_CRON=0 8 * * *
LIVE_POLL_INTERVAL_MS=300000
POLL_RESUME_DELAY_MS=120000
SYNC_ON_BOOT=false
# Auto-untrack a tournament once every match has finished and its last match
# started this many hours ago (checked during the daily morning sync). Default 72.
TOURNAMENT_UNTRACK_AFTER_HOURS=72

# --- EWC Club Championship ---
CC_REFRESH_MINUTES=15
CC_BOOT_DELAY_MS=45000
CS_RANKINGS_REFRESH_MINUTES=60
CS_RANKINGS_BOOT_DELAY_MS=90000
EWC_CLUB_CACHE_BOOT_DELAY_MS=120000
EWC_PREDICTIONS_REFRESH_MINUTES=15
EWC_PREDICTIONS_SCORE_DELAY_HOURS=24
# Send one no-ping reminder per game to existing incomplete participants.
EWC_PREDICTIONS_REMINDERS_ENABLED=true
# Hours before an individual game lock, clamped to 1-24.
EWC_PREDICTIONS_REMINDER_HOURS=6

# --- Cranl / PostgreSQL migration ---
# Cranl injects this automatically when the managed PostgreSQL database is attached
# to the application. The current runtime still uses SQLite until the DB layer is
# ported; these vars are for the PostgreSQL schema/import scripts and future cutover.
DATABASE_URL=
# Explicitly set `postgres` on Cranl after the runtime port is complete. Leave
# blank for current SQLite/local development behavior.
DB_DRIVER=
# Optional source override for `npm run db:sqlite-to-pg`; defaults to DB_PATH.
SQLITE_PATH=
# Postgres TLS mode (libpq-style):
#   verify-full  encrypt + verify the server certificate (RECOMMENDED in prod)
#   verify-ca    encrypt + verify the certificate chain
#   require      encrypt but do NOT verify the certificate
#   no-verify    alias of require (encrypt, no verification)
#   disable      no TLS (only for a plain-TCP/local endpoint)
# Leave blank only for local SQLite development. If blank with a Postgres
# DATABASE_URL that has no sslmode, the connection may be UNENCRYPTED.
PGSSLMODE=
# Optional path to a PEM root CA for verify-ca/verify-full (e.g. the managed
# Postgres provider's CA bundle). Leave blank to use the system trust store.
PGSSLROOTCERT=

# --- EWC news -> Discord auto-posting ---
# How often the bot polls for newly published / edited / unpublished news posts (milliseconds).
# Minimum enforced in code is 30000 (30s). Default 120000 (2 minutes).
NEWS_ANNOUNCE_INTERVAL_MS=120000

# --- Community comments / likes ---
# Comma-separated Discord role IDs that count as "verified members". A signed-in
# user must be in the guild (DISCORD_GUILD_ID) AND have one of these roles to
# comment or like. Membership/roles are checked server-side via the bot token
# (no extra OAuth scope). REQUIRED to enable commenting.
COMMUNITY_VERIFIED_ROLE_IDS=
# Hours a LINK-ONLY pending comment waits before auto-approving if no moderator
# acts. Profanity-flagged comments never auto-approve. Default 24.
COMMENT_AUTO_APPROVE_LINK_HOURS=24
# How many distinct user reports auto-hide a still-visible comment (drops it to
# 'pending' for moderator review; reversible). Default 3. Set 0 to disable
# auto-hide (reports then only flag the comment in the moderation queue).
COMMENT_REPORT_AUTOHIDE_THRESHOLD=3
# Extra comma-separated hostnames to add to the safe-link allowlist (extends the
# built-in defaults; never replaces them). Links to other hosts hold the comment
# for review. e.g. my-clan.gg,example.tv
COMMENT_ALLOWED_LINK_HOSTS=

# --- EWC web dashboard / Discord profile showcase ---
# Add this redirect URL in the Discord Developer Portal:
#   ${BETTER_AUTH_URL}/api/auth/callback/discord
BETTER_AUTH_SECRET=generate-a-32-byte-secret
BETTER_AUTH_URL=http://localhost:3000
EWC_DASHBOARD_PUBLIC_URL=http://localhost:3000
EWC_DASHBOARD_INTERNAL_URL=http://localhost:3000
EWC_DASHBOARD_INTERNAL_SECRET=generate-a-shared-internal-secret
# Public GitHub Sponsors profile used for open-source partner payments/recognition.
NEXT_PUBLIC_GITHUB_SPONSORS_URL=https://github.com/sponsors/devabdullahs
# Optional: Google Search Console HTML tag value. Paste only the content value,
# e.g. <meta name="google-site-verification" content="abc123" /> -> abc123.
EWC_GOOGLE_SITE_VERIFICATION=
# Optional IndexNow notification for published article URL changes. Generate a
# random 32+ character alphanumeric/hyphen key. The verification route exposes
# the key at the entropy-bearing root /<key>.txt URL required by the protocol.
EWC_INDEXNOW_ENABLED=false
EWC_INDEXNOW_KEY=
WEB_HOST=0.0.0.0
WEB_PORT=3000
# Optional explicit version used by the web update banner. If unset, the web app
# uses provider commit/deployment env vars or the container hostname.
ECB_DEPLOYMENT_VERSION=
RUN_BOT=true
RUN_WEB=true
# Super admins: full control incl. managing the admin roster, games, and media channels.
# (Comma-separated Discord user IDs.) These bootstrap the team — they can then add
# regular, game/channel-scoped admins from /admin/team.
EWC_DASHBOARD_SUPER_ADMIN_DISCORD_IDS=
# Legacy flat admin list — still honored and treated as SUPER admins for back-compat.
# Prefer EWC_DASHBOARD_SUPER_ADMIN_DISCORD_IDS for new deployments; both vars grant the same
# full access. Scoped (per-game/media-channel) admins are managed in the dashboard at
# /admin/team and stored in the database — no env change needed for them.
EWC_DASHBOARD_ADMIN_DISCORD_IDS=
EWC_DASHBOARD_DEFAULT_GUILD_ID=
EWC_DASHBOARD_DEV_AUTH_BYPASS=false
EWC_DASHBOARD_DEV_DISCORD_USER_ID=100000000000000001
# Local-dev fake identity (only used when EWC_DASHBOARD_DEV_AUTH_BYPASS=true)
EWC_DASHBOARD_DEV_AUTH_USER_ID=dev-local-auth-user
EWC_DASHBOARD_DEV_NAME=Local Discord Preview
# Admin MCP endpoint (/api/mcp). Keys are managed by super admins in /admin/mcp.
EWC_MCP_ENABLED=true
EWC_MCP_ALLOWED_ORIGINS=
EWC_MCP_RATE_LIMIT_PER_MINUTE=60
# Public read-only MCP endpoint (/api/public-mcp). No key required; exposes only
# data already visible on the public website/API. Rate limiting trusts only
# Cloudflare cf-connecting-ip; direct/non-Cloudflare requests share one fallback bucket.
EWC_PUBLIC_MCP_ENABLED=true
EWC_PUBLIC_MCP_ALLOWED_ORIGINS=
EWC_PUBLIC_MCP_RATE_LIMIT_PER_MINUTE=60
# First-party analytics ingestion limits. Source uses Cloudflare cf-connecting-ip;
# visitor uses the browser-local anonymous analytics visitor id.
EWC_ANALYTICS_SOURCE_RATE_LIMIT_PER_HOUR=600
EWC_ANALYTICS_VISITOR_RATE_LIMIT_PER_HOUR=300
# Client-IP trust for IP-keyed rate limits. "cloudflare" trusts the
# cf-connecting-ip header written by the Cloudflare/CranL ingress — the value
# must still parse as a real IPv4/IPv6 address (IPv6 buckets to /64); anything
# else falls into a shared "invalid" bucket. Set to "none" when the app is
# reached directly without a trusted proxy: ALL forwarding headers are then
# ignored and direct clients share one conservative bucket.
EWC_TRUSTED_PROXY=none

# --- News image uploads (Cloudflare R2, S3-compatible) ---
# When all of these are set, admins can upload images in the news editor (server-side
# upload, so credentials stay on the server and your GET-only bucket CORS is enough).
# Leave blank to disable uploads — admins can still paste image URLs.
# Create an R2 API token (Object Read & Write) in the Cloudflare dashboard.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL that serves the bucket (your connected custom domain), no trailing slash:
R2_PUBLIC_BASE_URL=https://assets.esportscommunity.net
# When the same R2 creds are set, the Liquipedia logo cache is ALSO persisted to
# R2 (under this key prefix) so it survives container/deploy wipes. Reads use the
# public URL above; writes use the S3 API. Leave default unless sharing a bucket.
R2_LOGO_PREFIX=esports-logo-cache

# --- Thmanyah font hosting ---
# The web app proxies these WOFF2 files from this public base URL without committing font files.
# Keep the folder layout as /thmanyahsans/woff2, /thmanyahserifdisplay/woff2,
# and /thmanyahseriftext/woff2.
THMANYAH_FONT_BASE_URL=https://assets.esportscommunity.net

# --- Misc ---
DB_PATH=data/bot.sqlite
SQLITE_BUSY_TIMEOUT_MS=5000
LOGO_CACHE_DIR=data/logo-cache
LOGO_DOWNLOAD_MIN_GAP_MS=10000
LOGO_UPSTREAM_MIN_GAP_MS=30000
LOGO_FAILURE_TTL_MS=900000
LOGO_RATE_LIMIT_BACKOFF_MS=1200000
LOGO_RATE_STATE_PATH=data/logo-rate-limit.json
LOGO_MAX_BYTES=4194304
# Public website logo proxy serves cached files by default. Keep false in production;
# set true only for a controlled one-off warmup if you understand the Liquipedia risk.
WEB_LOGO_PROXY_DOWNLOADS=false
LOG_LEVEL=info
