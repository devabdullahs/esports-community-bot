# Copy to .env and fill in. Loaded automatically via process.loadEnvFile()
# (or run: node --env-file=.env src/index.js)

# --- Discord (required) ---
DISCORD_TOKEN=your-bot-token
DISCORD_CLIENT_ID=your-application-id
DISCORD_CLIENT_SECRET=your-application-client-secret
# Optional: set to one server's ID to register slash commands instantly (dev).
# Leave blank to register globally (takes up to ~1h to propagate).
DISCORD_GUILD_ID=
# Optional: deploy slash commands when the bot process starts.
DEPLOY_DISCORD_COMMANDS=false

# --- PandaScore (VCT, LCS/Worlds, IEM/CS2, RLCS, OWCS, ...) ---
PANDASCORE_TOKEN=

# --- Start.gg (brackets; EWC + community events) ---
STARTGG_TOKEN=

# --- Liquipedia (PRIMARY, free) — REQUIRED by their ToS: identify app + a real contact ---
LIQUIPEDIA_USER_AGENT=EsportsCommunityBot/1.0 (you@example.com)
LIQUIPEDIA_PARSE_MIN_GAP_MS=30000
LIQUIPEDIA_CACHE_TTL_MS=300000
LIQUIPEDIA_BACKOFF_MS=1200000
LIQUIPEDIA_RATE_STATE_PATH=data/liquipedia-rate-limit.json
# Optional: LiquipediaDB API key (structured JSON, 60 req/hr). When set, it's preferred over
# HTML parsing. Leave blank to use the free MediaWiki parsing (current default).
LPDB_API_KEY=

# --- Scheduler ---
SCHEDULER_TIMEZONE=UTC
MORNING_CRON=0 8 * * *
LIVE_POLL_INTERVAL_MS=180000
SYNC_ON_BOOT=false

# --- EWC Club Championship ---
CC_REFRESH_MINUTES=15
CS_RANKINGS_REFRESH_MINUTES=60
EWC_PREDICTIONS_REFRESH_MINUTES=60
EWC_PREDICTIONS_SCORE_DELAY_HOURS=24

# --- EWC web dashboard / Discord profile showcase ---
# Add this redirect URL in the Discord Developer Portal:
#   ${BETTER_AUTH_URL}/api/auth/callback/discord
BETTER_AUTH_SECRET=generate-a-32-byte-secret
BETTER_AUTH_URL=http://localhost:3000
EWC_DASHBOARD_PUBLIC_URL=http://localhost:3000
EWC_DASHBOARD_INTERNAL_URL=http://localhost:3000
EWC_DASHBOARD_INTERNAL_SECRET=generate-a-shared-internal-secret
EWC_DASHBOARD_ADMIN_DISCORD_IDS=

# --- Misc ---
DB_PATH=data/bot.sqlite
LOGO_CACHE_DIR=data/logo-cache
LOGO_CACHE_CONCURRENCY=2
LOGO_DOWNLOAD_MIN_GAP_MS=2000
LOGO_FAILURE_TTL_MS=900000
LOGO_RATE_LIMIT_BACKOFF_MS=1200000
LOGO_RATE_STATE_PATH=data/logo-rate-limit.json
LOGO_MAX_BYTES=4194304
LOG_LEVEL=info
